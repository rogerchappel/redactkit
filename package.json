{
  "name": "@rogerchappel/redactkit",
  "version": "0.1.0",
  "description": "Local-first CLI for scrubbing secrets and private details from logs, transcripts, and fixtures.",
  "type": "module",
  "bin": {
    "redactkit": "./dist/src/cli.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --test dist/tests/*.test.js",
    "smoke": "bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "tsc -p tsconfig.json --noEmit && node --test dist/tests/*.test.js && bash scripts/smoke.sh && npm pack --dry-run"
  },
  "keywords": [
    "redaction",
    "secrets",
    "privacy",
    "logs",
    "cli"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
