{
  "name": "@rogerchappel/redactkit",
  "version": "0.1.0",
  "description": "Local-first CLI for scrubbing secrets and private details from logs, transcripts, and fixtures.",
  "type": "module",
  "bin": {
    "redactkit": "./dist/src/cli.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "examples",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "smoke": "bash scripts/smoke.sh",
    "package:smoke": "npm run build && node scripts/package-smoke.mjs",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke",
    "release:readiness": "node scripts/validate-release-readiness.mjs"
  },
  "keywords": [
    "redaction",
    "secrets",
    "privacy",
    "logs",
    "cli"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/redactkit.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/redactkit/issues"
  },
  "homepage": "https://github.com/rogerchappel/redactkit#readme",
  "packageManager": "pnpm@10.11.0",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
